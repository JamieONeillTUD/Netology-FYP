};

let guideUI = null;
let suggestionsHideTimer = null;
let terminalLayout = { collapsed: true };

const tutorialCarouselState = {
  hidden: localStorage.getItem(TUTORIAL_CAROUSEL_HIDDEN_KEY) === "1",
  index: 0, count: 0,
};

const API_BASE  = String(window.API_BASE || "").replace(/\/$/, "");
const ENDPOINTS = window.ENDPOINTS || {};
const XP        = window.NetologyXP || null;

const apiGet = window.apiGet || (async (path, params = {}) => {
  const base = API_BASE.trim();
  const url = base ? new URL(base.replace(/\/$/, "") + path) : new URL(path, window.location.origin);
  Object.entries(params || {}).forEach(([k, v]) => {
    if (v != null && v !== "") url.searchParams.set(k, String(v));
  });
  return (await fetch(url.toString())).json();
});

/* ── Generic utilities ───────────────────── */
function parseJsonSafe(str, fallback = null) { try { return JSON.parse(str); } catch { return fallback; } }
function getStoredUser() { return parseJsonSafe(localStorage.getItem("netology_user") || localStorage.getItem("user")); }
function escapeHtml(text) { return String(text ?? "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;"); }
function clearChildren(element) { if (element) element.replaceChildren(); }
function clamp(value, min, max) { return Math.min(max, Math.max(min, value)); }
function debounce(callback, delay) {
  let timer;
  return function (...args) {
    clearTimeout(timer);
    timer = setTimeout(() => callback.apply(this, args), delay);
  };
}

function makeEl(tag, className, text) {
  const el = document.createElement(tag);
  if (className) el.className = className;
  if (text !== undefined) el.textContent = text;
  return el;
}
function makeIcon(cls) { const i = document.createElement("i"); i.className = cls; return i; }
function makeSvgEl(tag) { return document.createElementNS("http://www.w3.org/2000/svg", tag); }

function setStatusBox(box, cls, icon, text) {
  if (!box) return;
  box.className = cls; clearChildren(box);
  const ic = makeIcon(`bi ${icon} me-1`); ic.setAttribute("aria-hidden", "true");
  box.append(ic, document.createTextNode(text));
}

function setText(id, text) { const el = getById(id); if (el) el.textContent = String(text ?? ""); }

function showToast({ title, message, variant = "info", timeout = 3200 }) {
  if (window.NetologyToast?.showSandboxToast)
    return window.NetologyToast.showSandboxToast({ title: title || "Update", message: message || "", variant, timeout });
  if (window.NetologyToast?.showMessageToast)
    window.NetologyToast.showMessageToast(message || title || "Update", variant, timeout);
}

/* ── Terminal panel (docked — just collapsed state) ── */
function persistTerminalCollapsed() {
  try { localStorage.setItem(TERMINAL_LAYOUT_KEY, JSON.stringify({ collapsed: Boolean(terminalLayout.collapsed) })); } catch {}
}
function loadTerminalLayout() {
  const saved = parseJsonSafe(localStorage.getItem(TERMINAL_LAYOUT_KEY));
  if (saved && typeof saved === "object") terminalLayout.collapsed = !!saved.collapsed;
}

/* ── Viewport / zoom / pan ───────────────── */
function getPanBounds(zoom = state.zoom) {
  const stageRect = stage.getBoundingClientRect();
  const scaledWidth = CANVAS_WIDTH * zoom;
  const scaledHeight = CANVAS_HEIGHT * zoom;
  let minX = stageRect.width - scaledWidth;
  let maxX = 0;
  let minY = stageRect.height - scaledHeight;
  let maxY = 0;
  if (scaledWidth <= stageRect.width) {
    const center = (stageRect.width - scaledWidth) / 2;
    minX = maxX = center;
  }
  if (scaledHeight <= stageRect.height) {
    const center = (stageRect.height - scaledHeight) / 2;
    minY = maxY = center;
  }
  return { minX, maxX, minY, maxY };
}

function clampPanToBounds() {
  const bounds = getPanBounds();
  state.panX = clamp(state.panX, bounds.minX, bounds.maxX);
  state.panY = clamp(state.panY, bounds.minY, bounds.maxY);
}
function toWorldPoint(clientX, clientY) {
  const stageRect = stage.getBoundingClientRect();
  return {
    x: (clientX - stageRect.left - state.panX) / state.zoom,
    y: (clientY - stageRect.top - state.panY) / state.zoom,
  };
}
function toScreenPoint(worldX, worldY) {
  return {
    x: state.panX + worldX * state.zoom,
    y: state.panY + worldY * state.zoom,
  };
}

function applyCanvasWorldSize() {
  const widthPx = `${CANVAS_WIDTH}px`;
  const heightPx = `${CANVAS_HEIGHT}px`;
  deviceLayer.style.width = widthPx;
  deviceLayer.style.height = heightPx;
  connectionLayer.style.width = widthPx;
  connectionLayer.style.height = heightPx;
  connectionLayer.setAttribute("width", String(CANVAS_WIDTH));
  connectionLayer.setAttribute("height", String(CANVAS_HEIGHT));
  connectionLayer.setAttribute("viewBox", `0 0 ${CANVAS_WIDTH} ${CANVAS_HEIGHT}`);
}

function resetViewport() {
  const stageRect = stage.getBoundingClientRect();
  state.zoom = 1;
  state.panX = (stageRect.width - CANVAS_WIDTH) / 2;
  state.panY = (stageRect.height - CANVAS_HEIGHT) / 2;
  clampPanToBounds();
}

function setZoom(next, anchorX = null, anchorY = null) {
  const newZoom = clamp(next, 0.4, 2.5);
  if (newZoom === state.zoom) return;
  if (Number.isFinite(anchorX) && Number.isFinite(anchorY)) {
    const stageRect = stage.getBoundingClientRect();
    const localX = anchorX - stageRect.left;
    const localY = anchorY - stageRect.top;
    const worldX = (localX - state.panX) / state.zoom;
    const worldY = (localY - state.panY) / state.zoom;
    state.zoom = newZoom;
    state.panX = localX - worldX * newZoom;
    state.panY = localY - worldY * newZoom;
  } else {
    state.zoom = newZoom;
  }
  clampPanToBounds();
  updateZoomLabel();
  renderConnections();
  renderConnectionLabels();
}

function setTip(message) { if (tipsEl) tipsEl.textContent = message; }

/* ── Network validation ──────────────────── */
function isValidIP(ip) {
  const octets = String(ip || "").trim().split(".");
  return octets.length === 4 && octets.every(octet => {
    const num = Number(octet);
    return Number.isInteger(num) && num >= 0 && num <= 255;
  });
}

const VALID_MASKS = new Set([
  "255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248",
  "255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128",
  "255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0",
  "255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0",
  "255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0",
  "255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0",
  "255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0",
  "240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0","0.0.0.0",
]);
function isValidSubnet(mask) { return VALID_MASKS.has(String(mask || "").trim()); }
function ipToInt(ip) {
  return String(ip).split(".").reduce((result, octet) => (result << 8) + parseInt(octet, 10), 0) >>> 0;
}

function isSameSubnet(ipA, ipB, mask) {
  if (!isValidIP(ipA) || !isValidIP(ipB) || !isValidSubnet(mask)) return false;
  const maskInt = ipToInt(mask);
  return (ipToInt(ipA) & maskInt) === (ipToInt(ipB) & maskInt);
}

function buildAutoLanIp(host) { return `${AUTO_NETWORK.prefix}${host}`; }

function pickAvailableAutoLanIp(used, preferred = null) {
  if (Number.isInteger(preferred)) {
    const ip = buildAutoLanIp(preferred);
    if (!used.has(ip)) return ip;
  }
  for (let host = AUTO_NETWORK.startHost; host <= AUTO_NETWORK.endHost; host++) {
    const candidate = buildAutoLanIp(host);
    if (!used.has(candidate)) return candidate;
  }
  for (let host = 2; host <= 254; host++) {
    const candidate = buildAutoLanIp(host);
    if (!used.has(candidate)) return candidate;
  }
  return "";
}

function generateMacAddress() { return "XX:XX:XX:XX:XX:XX".replace(/X/g, () => Math.floor(Math.random() * 16).toString(16).toUpperCase()); }

/* ── Device normalisation ────────────────── */
function generateInterfaces(type, count = 2) {
  if (type === "router") return Array.from({ length: count }, (_, i) => ({ id: `gig0/${i}`, name: `GigabitEthernet0/${i}`, status: "admin-down", speed: "1000Mbps", connectedTo: "", ipAddress: "" }));
  if (type === "switch") return Array.from({ length: 24 }, (_, i) => ({ id: `fa0/${i}`, name: `FastEthernet0/${i}`, status: "down", speed: "100Mbps", connectedTo: "" }));
  return [];
}

function normalizeDevice(raw) {
  const base = raw || {};
  const config = base.config || {};
  const type = base.type || "pc";
  return {
    id: base.id || `device-${Date.now()}-${Math.random().toString(16).slice(2)}`,
    type,
    x: Number(base.x ?? 200),
    y: Number(base.y ?? 200),
    name: base.name || (DEVICE_TYPES[type]?.label || "Device"),
    status: base.status || "on",
    config: {
      ipAddress:      config.ipAddress      ?? base.ipAddress   ?? base.ip      ?? "",
      subnetMask:     config.subnetMask     ?? base.subnetMask  ?? base.mask    ?? "255.255.255.0",
      defaultGateway: config.defaultGateway ?? base.defaultGateway ?? base.gateway ?? "",
      macAddress:     config.macAddress     ?? base.macAddress   ?? generateMacAddress(),
      dhcpEnabled:    config.dhcpEnabled    ?? base.dhcpEnabled  ?? false,
      interfaces:     config.interfaces     ?? base.interfaces   ?? generateInterfaces(type),
      routingTable:   config.routingTable   ?? base.routingTable ?? [],
      macTable:       config.macTable       ?? base.macTable     ?? [],
      dhcpServer:     config.dhcpServer     ?? base.dhcpServer   ?? ((type === "server" || type === "router") ? { enabled: false, network: "", mask: "255.255.255.0", gateway: "", rangeStart: "", rangeEnd: "", leases: [] } : null),
      dnsServer:      config.dnsServer      ?? base.dnsServer    ?? (type === "server" ? { enabled: false, records: [] } : null),
    },
  };
}

function normalizeConnection(raw) {
  if (!raw) return null;
  const from = raw.from || raw.a, to = raw.to || raw.b;
  if (!from || !to) return null;
  return {
    id: raw.id || `conn-${Date.now()}-${Math.random().toString(16).slice(2)}`,
    from, to, type: raw.type || "ethernet", status: raw.status || "active",
    fromInterface: raw.fromInterface || "", toInterface: raw.toInterface || "",
  };
}

/* ── Device lookup ───────────────────────── */
function findDevice(id) { return state.devices.find(d => d.id === id) || null; }
function getSelectedDevice() { return state.selectedIds.length === 1 ? findDevice(state.selectedIds[0]) : null; }
function findDeviceByName(name) {
  const search = String(name || "").trim().toLowerCase();
  return search ? state.devices.find(device => String(device.name || "").trim().toLowerCase() === search) || null : null;
}
function findDeviceByIp(ip) {
  const search = String(ip || "").trim();
  return isValidIP(search) ? state.devices.find(device => String(device.config?.ipAddress || "").trim() === search) || null : null;
}
function findDeviceByIdentifier(identifier) {
  const search = String(identifier || "").trim();
  return search ? (findDeviceByName(search) || findDeviceByIp(search)) : null;
}

/* ── Auto-network defaults ───────────────── */
function updateDeviceStatus(dev) {
  const ok = (!dev.config.ipAddress || isValidIP(dev.config.ipAddress))
    && (!dev.config.subnetMask || isValidSubnet(dev.config.subnetMask))
    && (!dev.config.defaultGateway || isValidIP(dev.config.defaultGateway));
  dev.status = ok ? "on" : "error";
}

function applyAutoNetworkDefaults({ force = false } = {}) {
  if (!state.devices.length) return;

  // Sort routers first so they get IPs assigned before other devices
  const ordered = [...state.devices].sort((a, b) => (a.type === "router" ? 0 : 1) - (b.type === "router" ? 0 : 1));
  const usedIps = new Set();
  let primaryRouterIp = "";

  // Pass 1: Assign IPs and subnet masks
  ordered.forEach(device => {
    if (!device?.config) return;
    if (force || !isValidSubnet(device.config.subnetMask)) device.config.subnetMask = AUTO_NETWORK.mask;
    if (device.type === "cloud") return;
    const currentIp = String(device.config.ipAddress || "").trim();
    if (force || !isValidIP(currentIp) || usedIps.has(currentIp)) {
      const preferred = device.type === "router" && !primaryRouterIp ? AUTO_NETWORK.routerHost : null;
      const newIp = pickAvailableAutoLanIp(usedIps, preferred);
      if (newIp) device.config.ipAddress = newIp;
    }
    const finalIp = String(device.config.ipAddress || "").trim();
    if (isValidIP(finalIp)) { usedIps.add(finalIp); if (!primaryRouterIp && device.type === "router") primaryRouterIp = finalIp; }
  });

  // Pass 2: Assign gateways and validate status
  state.devices.forEach(device => {
    if (!device?.config) return;
    if (device.type === "router" || device.type === "cloud") {
      if (force || !isValidIP(String(device.config.defaultGateway || "").trim())) device.config.defaultGateway = "";
    } else {
      const gateway = String(device.config.defaultGateway || "").trim();
      const gatewayExistsInTopology = gateway && state.devices.some(other => other.id !== device.id && String(other.config?.ipAddress || "").trim() === gateway);
      if (force || !gateway || !isValidIP(gateway) || gateway === device.config.ipAddress || !gatewayExistsInTopology) device.config.defaultGateway = primaryRouterIp || "";
    }
    updateDeviceStatus(device);
  });
}

/* ── Path-finding (BFS) ──────────────────── */
function findPath(fromId, toId) {
  const visited = new Set(), queue = [{ id: fromId, path: [fromId] }];
  while (queue.length) {
    const { id, path } = queue.shift();
    if (id === toId) return path;
    if (visited.has(id)) continue;
    visited.add(id);
    state.connections
      .filter(c => c.from === id || c.to === id)
      .map(c => c.from === id ? c.to : c.from)
      .forEach(next => { if (!visited.has(next)) queue.push({ id: next, path: [...path, next] }); });
  }
  return [];
}

/* ── MAC table rebuild ───────────────────── */
function rebuildMacTables() {
  state.devices.forEach(d => {
    if (d.type !== "switch") return;
    const entries = [];
    state.connections.filter(c => c.from === d.id || c.to === d.id).forEach((conn, idx) => {
      const other = findDevice(conn.from === d.id ? conn.to : conn.from);
      if (!other) return;
      entries.push({ macAddress: other.config.macAddress, port: d.config.interfaces?.[idx]?.name || `Fa0/${idx}`, age: 0 });
    });
    d.config.macTable = entries;
  });
}

/* ── Ping logic ──────────────────────────── */
function executePing(fromId, toId) {
  const from = findDevice(fromId), to = findDevice(toId), steps = [];
  if (!from) return;

  const fail = (step, msg, extra = {}) => {
    steps.push({ step, success: false, message: msg });
    setPingResult({ success: false, steps, message: msg }, { fromDevice: from, toDevice: to, path: extra.path || [] });
  };

  if (!from.config.ipAddress)           return fail("Source IP", "No IP configured");
  steps.push({ step: "Source IP", success: true, message: from.config.ipAddress });
  if (!to || !to.config.ipAddress)      return fail("Destination IP", "Destination missing");
  steps.push({ step: "Destination IP", success: true, message: to.config.ipAddress });
  if (!isValidSubnet(from.config.subnetMask)) return fail("Subnet", "Invalid subnet mask");

  const path = findPath(fromId, toId);
  if (!path.length) return fail("Connectivity", "No path", { path });

  const same = isSameSubnet(from.config.ipAddress, to.config.ipAddress, from.config.subnetMask);
  steps.push({ step: "Subnet", success: true, message: same ? "Local" : "Remote" });

  if (!same) {
    if (!from.config.defaultGateway)     return fail("Gateway", "No default gateway", { path });
    const gwDev = state.devices.find(d => d.config.ipAddress === from.config.defaultGateway);
    if (!gwDev)                          return fail("Gateway", "Gateway not in topology", { path });
    if (!path.includes(gwDev.id))        return fail("Gateway", "No route through gateway", { path });
    steps.push({ step: "Gateway", success: true, message: `Gateway: ${gwDev.name}` });
  }

  setPingResult({ success: true, steps, message: `Reply from ${to.config.ipAddress}`, latency: same ? 1 : 2 }, { fromDevice: from, toDevice: to, path });
  addPacketLog(`${from.name} → ${to.name} (${from.config.ipAddress} → ${to.config.ipAddress})`);
  animatePacket(path);
}

/* ── DHCP ────────────────────────────────── */
function requestDHCP(deviceId) {
  const dev = findDevice(deviceId);
  if (!dev) return;
  const servers = state.devices.filter(d => d.config?.dhcpServer?.enabled);
  if (!servers.length) { addConsoleOutput("DHCP: No enabled DHCP server found."); return; }
  const reachable = servers.filter(s => s.id === dev.id || findPath(dev.id, s.id).length > 0);
  if (!reachable.length) { addConsoleOutput("DHCP: DHCP server exists, but no route to server."); return; }

  const srv = reachable[0], cfg = srv.config.dhcpServer;
  if (!Array.isArray(cfg.leases)) cfg.leases = [];
  if (!isValidIP(cfg.rangeStart) || !isValidIP(cfg.rangeEnd)) { addConsoleOutput(`DHCP: Invalid pool range on ${srv.name}. Set valid Range Start and Range End in Config > DHCP.`); return; }
  const startIP = ipToInt(cfg.rangeStart), endIP = ipToInt(cfg.rangeEnd);
  if (startIP > endIP) { addConsoleOutput("DHCP: Range Start must be lower than or equal to Range End."); return; }

  const existing = cfg.leases.find(l => l.mac === dev.config.macAddress && isValidIP(l.ip));
  if (existing) {
    Object.assign(dev.config, { ipAddress: existing.ip, subnetMask: cfg.mask || "255.255.255.0", defaultGateway: cfg.gateway || "", dhcpEnabled: true });
    updateDeviceStatus(dev); addConsoleOutput(`DHCP: Reused ${existing.ip} for ${dev.name}`);
    renderDevices(); markDirtyAndSaveSoon(); return;
  }

  const usedIPs = new Set(cfg.leases.filter(l => isValidIP(l.ip)).map(l => ipToInt(l.ip)));
  let assigned = null;
  for (let ip = startIP; ip <= endIP; ip++) { if (!usedIPs.has(ip)) { assigned = ip; break; } }
  if (assigned === null) { addConsoleOutput("DHCP: No available IPs in pool"); return; }

  const ipStr = [(assigned >>> 24) & 255, (assigned >>> 16) & 255, (assigned >>> 8) & 255, assigned & 255].join(".");
  cfg.leases.push({ ip: ipStr, mac: dev.config.macAddress, hostname: dev.name, expiry: new Date(Date.now() + 86400000).toISOString() });
  Object.assign(dev.config, { ipAddress: ipStr, subnetMask: cfg.mask || "255.255.255.0", defaultGateway: cfg.gateway || "", dhcpEnabled: true });
  updateDeviceStatus(dev);
  addConsoleOutput(`DHCP: Assigned ${ipStr} to ${dev.name} via ${srv.name}`);
  addActionLog(`DHCP assigned ${ipStr} to ${dev.name}`);
  renderDevices(); markDirtyAndSaveSoon();
}

/* ── Device positioning ──────────────────── */
function getNextDevicePosition() {
  const stageRect = stage.getBoundingClientRect();
  const viewCenter = toWorldPoint(stageRect.left + stageRect.width / 2, stageRect.top + stageRect.height / 2);
  const centerX = viewCenter.x - DEVICE_RADIUS;
  const centerY = viewCenter.y - DEVICE_RADIUS;
  const padding = 16;
  if (!state.devices.length) return { x: clamp(centerX, padding, CANVAS_WIDTH - DEVICE_SIZE - padding), y: clamp(centerY, padding, CANVAS_HEIGHT - DEVICE_SIZE - padding) };
  const step = DEVICE_SIZE + 20;
  const index = state.devices.length - 1;
  const ringNumber = Math.floor(index / 8) + 1;
  const angle = index * 0.9;
  const radius = ringNumber * step;
  return {
    x: clamp(centerX + Math.cos(angle) * radius, padding, CANVAS_WIDTH - DEVICE_SIZE - padding),
    y: clamp(centerY + Math.sin(angle) * radius, padding, CANVAS_HEIGHT - DEVICE_SIZE - padding),
  };
}

function createDragGhost(type) {
  const meta = DEVICE_TYPES[type] || DEVICE_TYPES.pc;
  const ghost = document.createElement("div"); ghost.className = "sbx-drag-ghost";
  const wrap = makeEl("div", "sbx-drag-icon");
  wrap.appendChild(makeIcon(`bi ${meta.icon}`)); wrap.style.background = meta.color || "";
  ghost.append(wrap, makeEl("div", "sbx-drag-label", meta.label || "Device"));
  document.body.appendChild(ghost); return ghost;
}
function positionDragGhost(g, x, y) { if (g) { g.style.left = `${x}px`; g.style.top = `${y}px`; } }
